#!/usr/bin/env python3
"""Generate images using Google GenAI SDK."""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

from dotenv import load_dotenv

ENV_PATH = Path(__file__).resolve().parents[1] / ".env"
load_dotenv(ENV_PATH, override=True)


def _env_file_sets_google_application_credentials() -> bool:
    try:
        return any(
            line.strip().startswith("GOOGLE_APPLICATION_CREDENTIALS=")
            for line in ENV_PATH.read_text().splitlines()
        )
    except OSError:
        return False


def _normalize_google_application_credentials() -> None:
    creds = os.environ.get("GOOGLE_APPLICATION_CREDENTIALS", "")
    explicit_override = (
        _env_file_sets_google_application_credentials()
        or os.environ.get("NATIVE_MEDIA_ALLOW_GOOGLE_APPLICATION_CREDENTIALS") == "1"
    )
    if creds and not explicit_override:
        os.environ.pop("GOOGLE_APPLICATION_CREDENTIALS", None)
        return
    if creds and not os.path.isabs(creds):
        os.environ["GOOGLE_APPLICATION_CREDENTIALS"] = str((ENV_PATH.parent / creds).resolve())


_normalize_google_application_credentials()

from google import genai
from google.genai import types


NANO_BANANA_MODELS = {
    "nano-banana-pro": os.environ.get("IMAGE_MODEL_PRO", "gemini-3-pro-image-preview"),
    "nano-banana-2": os.environ.get("IMAGE_MODEL", "gemini-3.1-flash-image-preview"),
}

IMAGEN_MODELS = {
    "imagen": "imagen-4.0-generate-001",
    "imagen-fast": "imagen-4.0-fast-generate-001",
    "imagen-ultra": "imagen-4.0-ultra-generate-001",
}

ALL_MODELS = {**NANO_BANANA_MODELS, **IMAGEN_MODELS}
IMAGEN_ASPECT_RATIOS = {"1:1", "3:4", "4:3", "9:16", "16:9"}
NB_ASPECT_RATIOS = {"1:1", "3:2", "2:3", "3:4", "4:3", "4:5", "5:4", "9:16", "16:9", "21:9"}
MAX_REFERENCE_IMAGES = 10


def _build_vertex_client(project: str, location: str) -> genai.Client:
    return genai.Client(vertexai=True, project=project, location=location)


def _build_aistudio_client() -> genai.Client:
    key = os.environ.get("GEMINI_API_KEY", "")
    secondary = os.environ.get("GEMINI_API_KEY_SECONDARY", "")
    if not key:
        sys.exit("Error: GEMINI_API_KEY not set in environment.")
    try:
        return genai.Client(api_key=key)
    except Exception:
        if secondary:
            print("Primary API key failed, trying secondary...", file=sys.stderr)
            return genai.Client(api_key=secondary)
        raise


def _build_client(use_aistudio: bool, project: str, location: str) -> genai.Client:
    if use_aistudio:
        return _build_aistudio_client()
    return _build_vertex_client(project, location)


def _load_image_part(path: str) -> types.Part:
    ext = os.path.splitext(path)[1].lower()
    mime_map = {
        ".png": "image/png",
        ".jpg": "image/jpeg",
        ".jpeg": "image/jpeg",
        ".webp": "image/webp",
        ".gif": "image/gif",
    }
    with open(path, "rb") as f:
        return types.Part.from_bytes(data=f.read(), mime_type=mime_map.get(ext, "image/png"))


def _generate_nano_banana(
    client: genai.Client,
    model_id: str,
    prompt: str,
    aspect_ratio: str | None = None,
    image_size: str | None = None,
    input_image: str | None = None,
    reference_images: list[str] | None = None,
) -> bytes:
    image_config_kwargs = {}
    if aspect_ratio:
        image_config_kwargs["aspect_ratio"] = aspect_ratio
    if image_size:
        image_config_kwargs["image_size"] = image_size

    config_kwargs = {"response_modalities": ["IMAGE"]}
    if image_config_kwargs:
        config_kwargs["image_config"] = types.ImageConfig(**image_config_kwargs)

    contents = [prompt]
    if input_image:
        contents.append(_load_image_part(input_image))
    for ref_path in reference_images or []:
        contents.append(_load_image_part(ref_path))

    response = client.models.generate_content(
        model=model_id,
        contents=contents,
        config=types.GenerateContentConfig(**config_kwargs),
    )
    for part in response.candidates[0].content.parts:
        if part.inline_data and part.inline_data.data:
            return part.inline_data.data
    raise RuntimeError("No image data in response")


def _generate_imagen(
    client: genai.Client,
    model_id: str,
    prompt: str,
    aspect_ratio: str | None = None,
    number_of_images: int = 1,
) -> bytes:
    config_kwargs = {
        "number_of_images": min(number_of_images, 1) if "ultra" in model_id else number_of_images,
        "output_mime_type": "image/png",
        "person_generation": "allow_adult",
    }
    if aspect_ratio:
        config_kwargs["aspect_ratio"] = aspect_ratio

    response = client.models.generate_images(
        model=model_id,
        prompt=prompt,
        config=types.GenerateImagesConfig(**config_kwargs),
    )
    if not response.generated_images:
        raise RuntimeError("No images generated")
    return response.generated_images[0].image.image_bytes


def main() -> None:
    parser = argparse.ArgumentParser(description="Generate images via Google GenAI SDK")
    parser.add_argument("--prompt", "-p", required=True)
    parser.add_argument("--model", "-m", default="nano-banana-pro", choices=list(ALL_MODELS.keys()))
    parser.add_argument("--output", "-o", required=True)
    parser.add_argument("--aspect-ratio", "-a", default=None)
    parser.add_argument("--image-size", default=None)
    parser.add_argument("--number", "-n", type=int, default=1)
    parser.add_argument("--input-image", default=None, metavar="PATH")
    parser.add_argument("--reference-image", action="append", dest="reference_images", metavar="PATH")
    parser.add_argument("--use-aistudio", action="store_true")
    parser.add_argument("--project", default=os.environ.get("GOOGLE_CLOUD_PROJECT"))
    args = parser.parse_args()

    if not args.use_aistudio and not args.project:
        sys.exit("Error: GOOGLE_CLOUD_PROJECT not set.")

    model_key = args.model
    model_id = ALL_MODELS[model_key]
    is_imagen = model_key.startswith("imagen")
    reference_images = args.reference_images or []

    if is_imagen and (args.input_image or reference_images):
        sys.exit("Error: Imagen only supports text-to-image generation.")
    if args.image_size and is_imagen:
        sys.exit("Error: --image-size is not supported for Imagen models.")
    if args.aspect_ratio:
        valid = IMAGEN_ASPECT_RATIOS if is_imagen else NB_ASPECT_RATIOS
        if args.aspect_ratio not in valid:
            sys.exit(f"Error: Invalid aspect ratio '{args.aspect_ratio}' for {model_key}.")
    if len(reference_images) > MAX_REFERENCE_IMAGES:
        sys.exit(f"Error: Too many --reference-image paths (max {MAX_REFERENCE_IMAGES}).")
    for img_path in ([args.input_image] if args.input_image else []) + reference_images:
        if not os.path.isfile(img_path):
            sys.exit(f"Error: Image file not found: {img_path}")

    client = _build_client(args.use_aistudio, args.project, "global")

    try:
        if is_imagen:
            image_bytes = _generate_imagen(client, model_id, args.prompt, args.aspect_ratio, args.number)
        else:
            image_bytes = _generate_nano_banana(
                client,
                model_id,
                args.prompt,
                aspect_ratio=args.aspect_ratio,
                image_size=args.image_size,
                input_image=args.input_image,
                reference_images=reference_images,
            )
    except Exception as e:
        if is_imagen and not args.use_aistudio and ("global" in str(e).lower() or "404" in str(e)):
            client = _build_vertex_client(args.project, "us-central1")
            image_bytes = _generate_imagen(client, model_id, args.prompt, args.aspect_ratio, args.number)
        else:
            print(f"Error: {e}", file=sys.stderr)
            sys.exit(1)

    output_path = os.path.abspath(args.output)
    os.makedirs(os.path.dirname(output_path), exist_ok=True)
    with open(output_path, "wb") as f:
        f.write(image_bytes)
    print(f"MEDIA:{output_path}")


if __name__ == "__main__":
    main()
